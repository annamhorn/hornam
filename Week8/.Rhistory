col.regions=df$Color,
par.settings = list(axis.line = list(col = "transparent"),
strip.background = list(col = 'transparent'),
strip.border = list(col = 'transparent')),
scales = list(col = "transparent"),
colorkey=F,
key=myKey,
main="Landcover 2019")
