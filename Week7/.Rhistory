library(ggplot2)
library(dplyr)
library(lubridate)
df.Faylor$Depth <- as.factor(df$Depth)
create_plot <- function(nut) {
ggplot(df.Faylor %>% filter(!is.na(.data[[nut]])),
aes(main = "Mean Nutrient Concentrations", x = Date, y = .data[[nut]], color = Depth, group = Depth)) +
geom_line() +
geom_point() +
labs(title = nut, x = "", y = "mg/L") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
}
# 3. Arrange in a grid
p1 <- create_plot("NO3")
p2 <- create_plot("NO2")
p3 <- create_plot("PO4")
p4 <- create_plot("NH4")
grid.arrange(p1, p2, p3, p4, ncol = 2, nrow = 2)
##MODELING AND PREDICTING##
# Focus on Depth 0
depth_0 <- subset(df.Faylor, Depth == 0)
depth_0$Date <- as.Date(depth_0$Date, "%m/%d/%Y")
depth_0[c( "Depth", "NO3", "NO2", "PO4", "NH4", "X1.Day.PP", "X3.Day.PP", "X7.Day.PP", "X14.Day.PP", "X30.31.Day.PP", "CP", "CB", "BP", "WTEMP", "COND", "X..DO", "pH", "TURB")] <- lapply(depth_0[c("Depth", "NO3", "NO2", "PO4", "NH4", "X1.Day.PP", "X3.Day.PP", "X7.Day.PP", "X14.Day.PP", "X30.31.Day.PP","CP", "CB", "BP", "WTEMP", "COND", "X..DO", "pH", "TURB" )], as.numeric)
# Select relevant columns
cols <- c("X1.Day.PP", "X3.Day.PP", "X7.Day.PP", "X14.Day.PP", "X30.31.Day.PP",
"NO3", "NO2", "PO4", "NH4", "CP", "CB", "BP")
# Generate Spearman correlations
cor_matrix <- cor(depth_0[, cols], method = "spearman", use = "complete.obs")
print(cor_matrix)
if (!require("ggcorrplot")) install.packages("ggcorrplot")
