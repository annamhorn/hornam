library(ggcorrplot)
library(dplyr)
df0 <- subset(df.Faylor, Depth == 0)
colnames(df0) <- c("1 Day PP", "3 Day PP", "7 Day PP", "14 Day PP", "30-31 Day PP",
"NO3", "NO2", "PO4", "NH4", "CP", "CB", "BP")
# 3. Select your columns (Precipitation, Nutrients, and Phytoplankton)
# Note: R usually adds 'X' to column names starting with numbers
cols <- c("1 Day PP", "3 Day PP", "7 Day PP", "14 Day PP", "30-31 Day PP",
"NO3", "NO2", "PO4", "NH4", "CP", "CB", "BP")
# 4. Calculate Spearman Correlation Matrix
# 'use = "pairwise.complete.obs"' handles the NAs in your data
corr_matrix <- cor(df0[,cols], method = "spearman", use = "pairwise.complete.obs")
# 5. Create the Heatmap
ggcorrplot(corr_matrix,
type = "lower",    # Shows only the bottom triangle (easier to read)
lab = TRUE,        # Adds the correlation numbers on the plot
lab_size = 2,
colors = c("#6D9EC1", "white", "#E46726"), # Blue (neg) to Red (pos)
title = "Spearman Correlation Heatmap: Surface",
ggtheme = theme_minimal())
