county <- c("Snyder")
?gadm
Pa <- gadm(country="USA",level=2)
PA <- Pa[Pa$NAME_1 %in% state,]
#get the desired county and reproject it to nlcd crs
Sr <- st_as_sf(PA[PA$NAME_2 %in% county,])%>%
st_transform(crs = "+proj=aea +lat_1=29.5 +lat_2=45.5 +lat_0=23 +lon_0=-96
+x_0=0 +y_0=0 +ellps=GRS80 +towgs84=0,0,0,0,0,0,0 +units=m +no_defs")
class(Sr)
#reproject to WGS84 for species download in gbif
Sr_p <- st_transform(Kg, crs = "+proj=longlat +datum=WGS84")
#for 2019#
?get_nlcd
nlcd2019 <- get_nlcd(
Sr,
year = 2019,
label = "PA",
force.redo = T
)
