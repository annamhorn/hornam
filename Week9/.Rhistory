fit.gamma <- fitdist(soil.vegtrans$Fraxinus_excelsior, distr = "gamma")
fit.lnorm <- fitdist(soil.vegtrans$Fraxinus_excelsior, distr = "lnorm")
fit.nbinom <- fitdist(soil.vegtrans$Fraxinus_excelsior, distr = "nbinom")
fit.logis <- fitdist(soil.vegtrans$Fraxinus_excelsior, distr = "logis")
fit.geom <- fitdist(soil.vegtrans$Fraxinus_excelsior, distr = "geom")
gofstat(list(fit.norm, fit.gamma,
fit.nbinom, fit.logis, fit.geom))
gofstat(fit.norm)
gofstat(fit.norm)
gofstat(fit.gamma)
gofstat(fit.nbinom)
gofstat(fitlogis)
gofstat(fitgeom)
gofstat(fit.logis)
gofstat(fit.geom)
