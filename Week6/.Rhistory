# Read in the "Toscano_Griffen_Data.csv" data from GitHub and load the three packages we used in the tutorial this week.
# The paper these data came from is uploaded to Canvas as "Toscano&Griffen_2014_JAE..."
library(MASS)
library(MuMIn)
library(mgcv)
setwd("C:/GitHub/hornam/Week6")
df <- read.csv("Toscano_Griffen_Data.csv")
head(df)
# The authors used proportional consumption of prey as the (y) in their model, but did not include this in the dataset.
# So we are going to create it - run the following line, assuming "df" is your data frame (feel free to change that):
df$prop.cons <- df$eaten/df$prey
head(df)
glmm.mod <- glmmPQL(df$prop.cons~Object, random = ~ 1 | block, family = binomial, data= df)
glmm.mod <- glmmPQL(df$prop.cons, random = ~ 1 | block, family = binomial, data= df)
glmm.mod <- glmmPQL(prop.cons, random = ~ 1 | block, family = binomial, data= df)
glmm.mod <- glmmPQL(prop.cons~Object, random = ~ 1 | block, family = binomial, data= df)
glmm.mod <- glmmPQL(y~prop.cons, random = ~ 1 | block, family = binomial, data= df)
glmm.mod <- glmmPQL(prop.cons~carapace.width+claw.width+activity.level, random = ~ 1 | block, family = binomial, data= df)
summary(glmm.mod)
r.sqauredGLMM(glmm.mod)
r.squaredGLMM(glmm.mod)
#ADDITIVE MODEL#
glmm.mod.add <- glmmPQL(prop.cons~carapace.width+claw.width+activity.level, random = ~ 1 | block, family = binomial, data= df)
summary(glmm.mod.add)
plot(glmm.mod.add)
#INTERACTIVE MODEL#
glmm.mod.int <- glmmPQL(prop.cons~carapace.width*claw.width+activity.level, random = ~ 1 | block, family = binomial, data= df)
summary(glmm.mod.int)
plot(glm.mod.int)
plot(glmm.mod.int)
#ADDITIVE MODEL#
glmm.mod.add <- glmmPQL(prop.cons~carapace.width+claw.width+activity.level, random = ~ 1 | block, family = binomial, data= df)
summary(glmm.mod.add)
gam.mod.add <- gam(prop.cons~carapace.width+claw.width+activity.level, random = ~ 1 | block, family = binomial, data= df)
summary(gam.mod.add)
gam.mod.add <- gam(prop.cons~carapace.width+claw.width+activity.level, random = ~ 1 | block, family = binomial, data= df)
summary(gam.mod.add)
plot(gam.mod.add)
plot(gam.mod.add$residuals, ylim = c(-.1,.1))
plot(gam.mod.add$residuals, ylim = c(-.5,.5))
plot(gam.mod.add$residuals, ylim = c(-1,1))
plot(gam.mod.add$residuals, ylim = c(-10,10))
plot(gam.mod.add$residuals, ylim = c(-5,5))
plot(gam.mod.add$residuals, ylim = c(-4,4))
plot(gam.mod.add$residuals, ylim = c(-3,3))
gam.mod.int <- gam(prop.cons~carapace.width*claw.width+activity.level, random = ~ 1 | block, family = binomial, data= df)
gam.mod.int <- gam(prop.cons~carapace.width*claw.width+activity.level, random = ~ 1 | block, family = binomial, data= df)
summary(gam.mod.int)
plot(gam.mod.int$residuals, ylim=c(-3,3))
gam.mod.add <- gam(prop.cons~carapace.width+claw.width+activity.level, random = ~ 1 | block, family = binomial, data= df)
summary(gam.mod.add)
plot(gam.mod.add$residuals, ylim = c(-3,3))
gam.mod.int <- gam(prop.cons~carapace.width*claw.width+activity.level, random = ~ 1 | block, family = binomial, data= df)
summary(gam.mod.int)
plot(gam.mod.int$residuals, ylim=c(-3,3))
AIC(gam.mod.add, gam.mod.int)
#Activate/Install Packages##
library(ggplot2)
library(dataRetrieval)
library(leaflet)
#Code the interactive map in leaflet#
library(dataRetrieval)
library(dplyr)
cql_huc_wildcard <-
'{
"op": "like",
"args": [
{ "property": "hydrologic_unit_code" },
"02050301%" ]
}'
sites.huc8 <- read_waterdata(service="monitoring-locations",
CQL=cql_huc_wildcard)
huc8.sites.list <- unique(sites.huc8$monitoring_location_id)
print(huc8.sites.list)
write.csv(huc8.sites.list, file="C:/Github/mappingwithR/USGSdataretrieval.interactive/HUC8.csv")
huc8.meantempdata <- read_waterdata_continuous(monitoring_location_id = huc8.sites.list[900:1200],
parameter_code = "00010",
properties = c("value","time","monitoring_location_id"),
time =  c("2026-01-01", "2026-02-01"))
